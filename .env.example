# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Frontend (apps/web)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_URL=http://localhost:3001

# Backend (apps/api)
BOOTSTRAP_ADMIN_EMAIL=
PORT=3001

# CORS — comma-separated list of allowed origins for the API.
# Required in production so the frontend at aksana-29-nextjs-web.vercel.app
# can call the API. Supports `*.example.com` wildcard for preview deployments.
# Example (production):
#   CORS_ORIGIN=https://aksana-29-nextjs-web.vercel.app
# Example (production + preview deployments):
#   CORS_ORIGIN=https://aksana-29-nextjs-web.vercel.app,*.vercel.app
# Local dev falls back to http://localhost:3000 when this is unset.
CORS_ORIGIN=
